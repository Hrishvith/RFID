# Gmail SMTP credentials used by /server to send real OTP verification emails.
# Copy this file to .env and fill in real values - .env is gitignored.
#
# 1. Enable 2-Step Verification on the Gmail account you want to send from:
#    https://myaccount.google.com/security
# 2. Generate an App Password (NOT your normal Gmail password):
#    https://myaccount.google.com/apppasswords
# 3. Paste the sending Gmail address and the 16-character app password below.

GMAIL_USER=your-address@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Only this email is allowed to log in to the dashboard - everyone else is
# rejected even with correct credentials. Change this to switch admins.
ADMIN_EMAIL=your-admin-address@gmail.com

# MongoDB connection string (e.g. from MongoDB Atlas).
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# --- Frontend (Vite) ---
# Base URL of the deployed Express auth server, including /api.
# Only needed in production - falls back to http://localhost:4000/api
# for local dev. Set this in Vercel's project environment variables,
# not here (this file is just for local reference).
VITE_AUTH_API_URL=https://your-render-service.onrender.com/api
