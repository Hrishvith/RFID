# Brevo API key used by /server to send real OTP verification emails.
# Copy this file to .env and fill in real values - .env is gitignored.
# Raw SMTP (Gmail) doesn't work on hosts like Render that block outbound
# SMTP ports, so OTP emails go through Brevo's HTTPS API instead. Unlike
# Resend's sandbox mode, Brevo's free tier (300 emails/day) can email any
# recipient once the sender address below is verified - no domain needed.
#
# 1. Sign up at https://app.brevo.com (free).
# 2. Verify BREVO_FROM_EMAIL as a sender: Senders, Domains & Dedicated IPs
#    > Senders > Add a sender - Brevo emails a confirmation link to it.
# 3. Create an API key: Settings (gear icon) > SMTP & API > API Keys > Generate a new API key.

BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx
BREVO_FROM_EMAIL=your-verified-sender@gmail.com
BREVO_FROM_NAME=RFID Smart Attendance

# Only this email is allowed to log in to the dashboard - everyone else is
# rejected even with correct credentials. Change this to switch admins.
ADMIN_EMAIL=your-admin-address@gmail.com

# MongoDB connection string (e.g. from MongoDB Atlas).
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# --- Frontend (Vite) ---
# Base URL of the deployed Express auth server, including /api.
# Only needed in production - falls back to http://localhost:4000/api
# for local dev. Set this in Vercel's project environment variables,
# not here (this file is just for local reference).
VITE_AUTH_API_URL=https://your-render-service.onrender.com/api
